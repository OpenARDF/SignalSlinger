* text=auto

# Keep source, docs, and CAD text data consistent across platforms.
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.html text eol=lf
*.csv text eol=lf
*.pos text eol=lf
*.rpt text eol=lf
*.dox text eol=lf
*.rst text eol=lf
*.h text eol=lf
*.c text eol=lf
*.cpp text eol=lf
*.S text eol=lf
*.kicad_sch text eol=lf
*.kicad_pcb text eol=lf
*.kicad_pro text eol=lf
*.kicad_prl text eol=lf
*.kicad_sym text eol=lf
*.kicad_mod text eol=lf
*.gbr text eol=lf
*.gbrjob text eol=lf
*.drl text eol=lf
*.ipc text eol=lf
*.pretty/** text eol=lf

# Preserve Windows-native line endings for local tooling.
*.ps1 text eol=crlf
*.sln text eol=crlf
*.cppproj text eol=crlf
*.componentinfo.xml text eol=crlf

# Treat generated artifacts and CAD bundles as binary.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.zip binary
*.xlsx binary
*.numbers binary
*.step binary
*.FCStd binary
*.atsuo binary
*.elf binary
*.hex binary
*.eep binary
*.srec binary
